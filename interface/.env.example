# Google Maps Places (autocomplete de endereço da modelo).
# Habilite Maps JavaScript API + Places API (New) no Google Cloud Console
# e restrinja por HTTP referrers (localhost:3000, domínio prod).
# Sem a chave, o campo de endereço cai em input texto comum.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Playwright e2e — credenciais do usuário de teste (Fernando) no Supabase Auth.
# Lidas por tests/e2e/auth.setup.ts via dotenv (carregado no playwright.config.ts).
# Em CI, exporte como secrets do runner. Localmente, defina em .env (gitignored)
# ou via env var User-level do SO para cobrir também processos fora do Playwright.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
