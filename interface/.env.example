# Google Maps — autocomplete de endereço (CampoLocalAutocomplete) + Mapa de clientes (MapaClientes).
# Habilite SÓ estas duas APIs nesta key, no Google Cloud Console:
#   - Maps JavaScript API  (renderiza o mapa + marcadores)
#   - Places API (New)     (PlaceAutocompleteElement do autocomplete)
# Geocoding API NÃO é necessária: o lat/long vem do place.location da Places API (New), no browser.
# Restrinja por HTTP referrers (http://localhost:3000/*, https://<domínio-prod>/*).
# Sem a chave, o campo de endereço cai em input texto comum.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Playwright e2e — credenciais do usuário de teste (Fernando) no Supabase Auth.
# Lidas por tests/e2e/auth.setup.ts via dotenv (carregado no playwright.config.ts).
# Em CI, exporte como secrets do runner. Localmente, defina em .env (gitignored)
# ou via env var User-level do SO para cobrir também processos fora do Playwright.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
