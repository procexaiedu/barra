# --- App ---
AMBIENTE=desenvolvimento
LOG_LEVEL=INFO

# --- Supabase / Postgres (Supavisor 6543, transaction mode) ---
DATABASE_URL=postgresql://postgres.SEU_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://SEU_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Redis (self-host) ---
REDIS_URL=redis://:SENHA@localhost:6379/0

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_MEDIA=barra-media
MINIO_USE_SSL=false

# --- Anthropic ---
LLM_CHAT_PROVIDER=openrouter
LLM_VISION_PROVIDER=openrouter
LLM_AUDIO_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL_CHAT=
OPENROUTER_MODEL_VISION_PIX=
# (legado, removido ao fim do M5 — STT direto pela OpenAI, ver OPENAI_* abaixo)
OPENROUTER_MODEL_AUDIO_TRANSCRIBE=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_CHAT=
ANTHROPIC_MODELO_PRINCIPAL=claude-sonnet-4-6

# --- OpenAI (STT do agente — 06 §1.3) ---
OPENAI_API_KEY=
OPENAI_MODEL_AUDIO_TRANSCRIBE=whisper-1

# --- LangSmith ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=barra-vips-dev

# --- Evolution API ---
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_TOKEN=
# URL pública do nosso /webhook/evolution. Em dev local, use um tunnel
# (ngrok/cloudflared) — sem isso, a Evolution não consegue postar eventos
# CONNECTION_UPDATE no backend, e o pareamento converge apenas via polling
# defensivo do painel (GET /modelos/{id}/whatsapp/status).
EVOLUTION_WEBHOOK_CALLBACK_URL=
EVOLUTION_GRUPO_COORDENACAO_JID=
EVOLUTION_FERNANDO_JIDS=[]
CORS_ORIGINS=["http://localhost:3000"]
# Regex opcional para liberar previews da Vercel (production + git previews + deployment hashes).
# Avalia em conjunto com CORS_ORIGINS — basta um dos dois bater para o origin ser aceito.
CORS_ORIGIN_REGEX=

# --- Filtro de ambiente teste (Fase 1.5) ---
# JID do grupo de teste — IA só processa mensagens vindas deste JID até promoção.
JID_PERMITIDO=

# --- Sentry ---
SENTRY_DSN=
