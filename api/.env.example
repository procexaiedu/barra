# --- App ---
AMBIENTE=desenvolvimento
LOG_LEVEL=INFO

# --- Supabase / Postgres (Supavisor 6543, transaction mode) ---
DATABASE_URL=postgresql://postgres.SEU_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://SEU_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Redis (self-host) ---
REDIS_URL=redis://:SENHA@localhost:6379/0

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_MEDIA=barra-media
MINIO_USE_SSL=false

# --- DeepSeek (texto do agente: chat #1 + extração #2 + judge de AUP #3) ---
# Os 3 caminhos de texto rodam DeepSeek V4 Flash DIRETO (api.deepseek.com). DEEPSEEK_API_KEY é
# OBRIGATÓRIA — o boot falha sem ela (settings._validar_providers_llm).
DEEPSEEK_API_KEY=
# id do V4 Flash; vazio -> default deepseek-v4-flash (aliases legados deepseek-chat/deepseek-reasoner
# aposentam 2026-07-24).
DEEPSEEK_MODEL_CHAT=deepseek-v4-flash
# temperatura do chat #1 (recomendacao oficial DeepSeek ~1.3); extracao/judge ignoram (determinismo).
CHAT_TEMPERATURE=1.3

# --- OpenRouter (vision do Pix; DeepSeek não faz imagem) ---
LLM_VISION_PROVIDER=openrouter
LLM_AUDIO_PROVIDER=openrouter
OPENROUTER_API_KEY=
# vision do Pix; vazio -> default google/gemini-3-flash-preview (pix.py). Pinar versao datada
# (google/gemini-3-flash-preview-20251217) se quiser estabilidade do preview.
OPENROUTER_MODEL_VISION_PIX=
# (legado, removido ao fim do M5 — STT direto pela OpenAI, ver OPENAI_* abaixo)
OPENROUTER_MODEL_AUDIO_TRANSCRIBE=

# --- Anthropic (DORMANTE: só LLM-judge dos evals + preaquecimento de cache; NÃO serve o chat) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODELO_PRINCIPAL=claude-sonnet-4-6
# modelo do LLM-judge dos evals; vazio -> usa ANTHROPIC_MODELO_PRINCIPAL.
ANTHROPIC_MODELO_JUDGE=

# --- OpenAI (STT do agente — 06 §1.3) ---
OPENAI_API_KEY=
OPENAI_MODEL_AUDIO_TRANSCRIBE=whisper-1

# --- LangSmith ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=barra-vips-dev

# --- Evolution API ---
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_TOKEN=
# URL pública do nosso /webhook/evolution. Em dev local, use um tunnel
# (ngrok/cloudflared) — sem isso, a Evolution não consegue postar eventos
# CONNECTION_UPDATE no backend, e o pareamento converge apenas via polling
# defensivo do painel (GET /modelos/{id}/whatsapp/status).
EVOLUTION_WEBHOOK_CALLBACK_URL=
EVOLUTION_GRUPO_COORDENACAO_JID=
EVOLUTION_FERNANDO_JIDS=[]
CORS_ORIGINS=["http://localhost:3000"]
# Regex opcional para liberar previews da Vercel (production + git previews + deployment hashes).
# Avalia em conjunto com CORS_ORIGINS — basta um dos dois bater para o origin ser aceito.
CORS_ORIGIN_REGEX=

# --- Filtro de ambiente teste (Fase 1.5) ---
# Allowlist (JSON) de JIDs de teste — IA só processa mensagens vindas destes JIDs.
# Pine o grupo do cliente E o grupo de Coordenação, senão o comando de fechamento no
# grupo leva 403. Vazio = desligado. Ex.: ["120363...@g.us","120363...@g.us"]
JID_PERMITIDO=[]

# --- Reengajamento proativo (docs/agente/07 §4.5; CONTEXT.md "Reengajamento") ---
# Default false no piloto: ligar manualmente quando a persona e a reputação do número
# estiverem calibradas. Quando false, o cron reengajar_silenciosos não dispara.
REENGAJAMENTO_ATIVO=false
REENGAJAMENTO_DELAY_MIN=30
# Janela local BRT [inicio, fim). fim < inicio cruza a meia-noite (ex.: 10-2 = 10h às 02h).
OPERACAO_HORA_INICIO=10
OPERACAO_HORA_FIM=2

# --- Sentry ---
SENTRY_DSN=
