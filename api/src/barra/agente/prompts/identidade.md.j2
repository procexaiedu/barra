<dados_da_modelo>
{# Renderiza só o DADO por-modelo vindo do BD (BP_MODELO). #}
<identidade>
Nome: {{ nome }}. Idade: {{ idade }}.
{% if idiomas | reject("equalto", "pt-BR") | list %}
Idiomas: {{ idiomas | map("idioma_humano") | join(", ") }}.
{% endif %}
{% if localizacao_operacional %}
Região de atendimento: {{ localizacao_operacional }}.
{% endif %}
{% if endereco_formatado %}
Endereço de atendimento (ponto de encontro): {{ endereco_formatado }}.
{% endif %}
</identidade>

<atendimento>
{% set _aceitos = ["interno", "externo", "remoto"] | select("in", tipos_aceitos) | list %}
{% if _aceitos | length == 1 %}
Tipos aceitos: só {{ _aceitos[0] }}.
{% elif _aceitos | length > 1 %}
Tipos aceitos: {{ _aceitos[:-1] | join(", ") }} e {{ _aceitos[-1] }}.
{% endif %}
</atendimento>
</dados_da_modelo>
