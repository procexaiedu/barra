<estado_atual>
<atendimento numero="#{{ numero_curto }}" estado="{{ estado }}" tipo="{{ tipo_atendimento or 'ainda não definido' }}" urgencia="{{ urgencia or 'não capturada' }}"/>
<pix_deslocamento>{{ pix_status }}</pix_deslocamento>
{% if data_desejada %}<horario_desejado>{{ data_desejada }} às {{ horario_desejado }}</horario_desejado>{% endif %}
{% if endereco %}<endereco>{{ endereco }}{% if bairro %} ({{ bairro }}){% endif %}</endereco>{% endif %}
</estado_atual>

<cliente nome="{{ cliente_nome or 'ainda não informado' }}" recorrente="{{ 'sim' if recorrente else 'não' }}">
{% if historico_anteriores %}<historico>{{ historico_anteriores }}</historico>{% endif %}
{% if ultimo_motivo_perda %}<ultimo_motivo_perda>{{ ultimo_motivo_perda }}</ultimo_motivo_perda>{% endif %}
{% if observacoes_internas %}<observacoes_internas>{{ observacoes_internas }}</observacoes_internas>{% endif %}
</cliente>

<agenda hoje="{{ data_atual }}" janela="próximas 48h">
{% if bloqueios %}{% for b in bloqueios %}<bloqueio inicio="{{ b.inicio.strftime('%a %d/%m %H:%M') }}" fim="{{ b.fim.strftime('%H:%M') }}" estado="{{ b.estado }}"/>
{% endfor %}{% else %}<livre>sem bloqueios nas próximas 48h, nenhum horário ocupado</livre>
{% endif %}</agenda>

<periodo_de_trabalho>
{% if disponibilidade %}{% for d in disponibilidade %}<regra dia="{{ d.dia }}" inicio="{{ d.hora_inicio }}" fim="{{ d.hora_fim }}" desde="{{ d.data_inicio }}"{% if d.data_fim %} ate="{{ d.data_fim }}"{% endif %}/>
{% endfor %}<observacao>fora desses dias/horários você está de folga ou viajando — diga quando volta e ofereça a data disponível mais próxima</observacao>
{% else %}<sem_restricao>você atende qualquer dia, respeitando só os bloqueios das próximas 48h</sem_restricao>
{% endif %}</periodo_de_trabalho>
