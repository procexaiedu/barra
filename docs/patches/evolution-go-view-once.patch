 		})
 
 		if err != nil {
@@ -2347,6 +2353,36 @@ func (s *sendService) SendList(data *ListStruct, instance *instance_model.Instan
 	return message, nil
 }
 
+// applyViewOnce marks an image/video/audio message as view-once and wraps it in the
+// ViewOnceMessageV2 envelope WhatsApp clients expect. Both are needed: the inner `viewOnce`
+// flag is what older clients read, the wrapper is what current iOS/Android/Web render as the
+// "1" badge. Any other message type is returned untouched (view-once is media-only).
+func applyViewOnce(msg *waE2E.Message, messageType string) *waE2E.Message {
+	switch messageType {
+	case "ImageMessage":
+		if msg.ImageMessage == nil {
+			return msg
+		}
+		msg.ImageMessage.ViewOnce = proto.Bool(true)
+	case "VideoMessage":
+		if msg.VideoMessage == nil {
+			return msg
+		}
+		msg.VideoMessage.ViewOnce = proto.Bool(true)
+	case "AudioMessage":
+		if msg.AudioMessage == nil {
+			return msg
+		}
+		msg.AudioMessage.ViewOnce = proto.Bool(true)
+	default:
+		return msg
+	}
+
+	return &waE2E.Message{
+		ViewOnceMessageV2: &waE2E.FutureProofMessage{Message: msg},
+	}
+}
+
 func (s *sendService) SendMessage(instance *instance_model.Instance, msg *waE2E.Message, messageType string, data *SendDataStruct) (*MessageSendStruct, error) {
 	s.loggerWrapper.GetLogger(instance.Id).LogInfo("[%s] SendMessage called for number: %s, type: %s", instance.Id, data.Number, messageType)
 
@@ -2770,6 +2806,13 @@ func (s *sendService) SendMessage(instance *instance_model.Instance, msg *waE2E.
 		sendExtra.AdditionalNodes = data.AdditionalNodes
 	}
 
+	// View-once: aplicado DEPOIS do ContextInfo (quote/menções/forward), que é resolvido pelo
+	// `messageType` sobre o msg cru — envolver antes deixaria msg.ImageMessage nil e mataria a
+	// citação. Newsletter/canal não suporta view-once, então o flag é ignorado lá.
+	if data.ViewOnce && recipient.Server != "newsletter" {
+		msg = applyViewOnce(msg, messageType)
+	}
+
 	response, err := s.clientPointer[instance.Id].SendMessage(context.Background(), recipient, msg, sendExtra)
 	if err != nil {
 		s.loggerWrapper.GetLogger(instance.Id).LogError("[%s] Error sending message: %v", instance.Id, err)
diff --git a/pkg/sendMessage/service/view_once_test.go b/pkg/sendMessage/service/view_once_test.go
new file mode 100644
index 0000000..e4df757
--- /dev/null
+++ b/pkg/sendMessage/service/view_once_test.go
@@ -0,0 +1,53 @@
+package send_service
+
+import (
+	"testing"
+
+	"go.mau.fi/whatsmeow/proto/waE2E"
+	"google.golang.org/protobuf/proto"
+)
+
+func TestApplyViewOnceWrapsImage(t *testing.T) {
+	msg := &waE2E.Message{ImageMessage: &waE2E.ImageMessage{
+		Caption: proto.String("hi"),
+		// ContextInfo is set before the wrap, so it must survive inside the envelope.
+		ContextInfo: &waE2E.ContextInfo{StanzaID: proto.String("QUOTED")},
+	}}
+
+	out := applyViewOnce(msg, "ImageMessage")
+
+	if out.ViewOnceMessageV2 == nil {
+		t.Fatal("expected the message to be wrapped in ViewOnceMessageV2")
+	}
+	inner := out.ViewOnceMessageV2.Message.GetImageMessage()
+	if !inner.GetViewOnce() {
+		t.Error("expected the inner ImageMessage to carry viewOnce=true")
+	}
+	if inner.GetContextInfo().GetStanzaID() != "QUOTED" {
+		t.Error("expected the quote ContextInfo to survive the wrap")
+	}
+}
+
+func TestApplyViewOnceWrapsVideoAndAudio(t *testing.T) {
+	video := applyViewOnce(&waE2E.Message{VideoMessage: &waE2E.VideoMessage{}}, "VideoMessage")
+	if !video.ViewOnceMessageV2.Message.GetVideoMessage().GetViewOnce() {
+		t.Error("expected video to be view-once")
+	}
+
+	audio := applyViewOnce(&waE2E.Message{AudioMessage: &waE2E.AudioMessage{}}, "AudioMessage")
+	if !audio.ViewOnceMessageV2.Message.GetAudioMessage().GetViewOnce() {
+		t.Error("expected audio to be view-once")
+	}
+}
+
+func TestApplyViewOnceIgnoresNonMedia(t *testing.T) {
+	msg := &waE2E.Message{DocumentMessage: &waE2E.DocumentMessage{}}
+
+	if out := applyViewOnce(msg, "DocumentMessage"); out.ViewOnceMessageV2 != nil {
+		t.Error("view-once is media-only; document must be sent untouched")
+	}
+	// A type/payload mismatch must not panic nor wrap an empty message.
+	if out := applyViewOnce(&waE2E.Message{}, "ImageMessage"); out.ViewOnceMessageV2 != nil {
+		t.Error("expected a nil ImageMessage to be returned untouched")
+	}
+}
