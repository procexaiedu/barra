 		// Accept multiple values (mentionedJid=x&mentionedJid=y) or a single
@@ -223,6 +226,7 @@ func (s *sendHandler) SendMedia(ctx *gin.Context) {
 			MentionAll:   mentionAll,
 			MentionedJID: mentionedJID,
 			Quoted:       quoted,
+			ViewOnce:     viewOnce,
