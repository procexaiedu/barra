# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/
.venv/
venv/
ENV/
.pytest_cache/
pytest-cache-files-*/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# --- uv ---
# .python-version é commitado de propósito (pin do interpretador)

# --- Node / Next.js ---
node_modules/
.next/
out/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts

# --- Logs ---
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Env & segredos ---
.env
.env.local
.env.*.local
*.pem
*.key
!.env.example

# --- IDE ---
.idea/
.vscode/*
!.vscode/settings.json.example
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Worktrees externos ---
.trees/
# Worktrees criados por subagentes do Claude Code
.claude/worktrees/
# Lock do agendador (ScheduleWakeup) — runtime do harness, não config do projeto
.claude/scheduled_tasks.lock
# Permissões locais do Claude Code — config por máquina, não vai pro repo.
.claude/settings.local.json
# Logs locais de execução de agentes/skills — só local
.claude/logs/

# --- Config local de MCP servers ---
# Cada dev/ambiente aponta para project_ref próprio do Supabase; não deve entrar no repo
.mcp.json

# --- Banco local / temp ---
*.sqlite
*.sqlite3
*.db
tmp/
temp/

# --- Docker ---
.docker/

# --- Playwright MCP snapshots ---
# Capturam DOM acessível, incluindo valores digitados em campos de senha. Nunca commitar.
.playwright-mcp/

# --- Evidências do Playwright (screenshots) ---
# PNGs gerados por mcp__playwright__browser_take_screenshot não vão pro repo.
# Exceções: screenshots permanentes em docs/ e assets em interface/public/.
*.png
!docs/**/*.png
!interface/public/**/*.png
.playwright-evidence/

# DevContext
.devcontext
