*.tsbuildinfo
next-env.d.ts

# --- Logs ---
*.log
logs.txt
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Env & segredos ---
.env
.env.local
.env.*.local
*.pem
*.key
!.env.example

# --- IDE ---
.idea/
.vscode/*
!.vscode/settings.json.example
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
*.stackdump

# --- Worktrees externos ---
.trees/
# Worktrees criados por subagentes do Claude Code
.claude/worktrees/
# Lock do agendador (ScheduleWakeup) — runtime do harness, não config do projeto
.claude/scheduled_tasks.lock
# Permissões locais do Claude Code — config por máquina, não vai pro repo.
.claude/settings.local.json
# Memória pessoal do Claude Code (URLs de sandbox, credenciais de teste) — nunca no repo.
CLAUDE.local.md
# Logs locais de execução de agentes/skills — só local
.claude/logs/
# Skills do Claude Code (ferramental por-máquina, não código do projeto)
.claude/skills/
.agents/

# --- Config local de MCP servers ---
# Cada dev/ambiente aponta para project_ref próprio do Supabase; não deve entrar no repo
.mcp.json

# --- Banco local / temp ---
*.sqlite
*.sqlite3
*.db
tmp/
temp/

# --- Docker ---
.docker/

# --- Playwright MCP snapshots ---
# Capturam DOM acessível, incluindo valores digitados em campos de senha. Nunca commitar.
.playwright-mcp/

# --- Evidências do Playwright (screenshots) ---
# PNGs gerados por mcp__playwright__browser_take_screenshot não vão pro repo.
# Exceções: screenshots permanentes em docs/ e assets em interface/public/.
*.png
!docs/**/*.png
!interface/public/**/*.png
.playwright-evidence/

# DevContext
.devcontext

# --- Artefatos de trabalho local (debug dumps / prints soltos) ---
# Dumps de depuração e prints de evals gerados na raiz; não vão pro repo.
_dump_*.txt
/evals-*.jpeg
/evals-*.jpg

# Export de contatos reais (PII de clientes); só local, nunca no repo.
contacts*.csv

# Artefatos de eval do corpus (contêm @lid de clientes reais — PII); só local, nunca no repo.
scripts/eval_corpus/

# --- migracao entre maquinas (scripts locais) ---
_migracao/

# Artefatos locais: extensao do VS Code e prompt renderizado (saida gerada). Nunca no repo.
*.vsix
prompt_agente_renderizado.md
